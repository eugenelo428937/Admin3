# Django Environment Configuration Template
# Copy this file to .env.development and fill in the actual values

# Django Core Settings
DJANGO_SETTINGS_MODULE=django_Admin3.settings.development
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=postgres://username:password@localhost:5432/dbname

# Individual Database Settings (alternative to DATABASE_URL)
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Administrate API Settings
ADMINISTRATE_API_URL=https://api.getadministrate.com/graphql
ADMINISTRATE_INSTANCE_URL=your-instance.administrateapp.com
ADMINISTRATE_API_KEY=your_api_key
ADMINISTRATE_API_SECRET=your_api_secret
ADMINISTRATE_REST_API_URL=https://your-instance.administrateapp.com
ADMINISTRATE_AUTH_USER=your_admin_email

# Security Settings
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Address Lookup Service
GETADDRESS_API_KEY=your_getaddress_api_key
GETADDRESS_ADMIN_KEY=your_getaddress_admin_key

# Email Settings
# Option 1: SendGrid (for Railway deployment)
USE_SENDGRID=False
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Option 2: Internal SMTP Server
USE_INTERNAL_SMTP=False
EMAIL_HOST=smtp.example.com
EMAIL_PORT=25
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your_smtp_username
EMAIL_HOST_PASSWORD=your_smtp_password
EMAIL_AUTH_METHOD=CRAM-MD5  # Options: CRAM-MD5, PLAIN, LOGIN, STANDARD

# Option 3: Gmail SMTP (for local development)
# (uses EMAIL_HOST_USER and EMAIL_HOST_PASSWORD with Gmail's settings)

# Email From/Reply-To Configuration
EMAIL_FROM_NAME=ActEd Sales
DEFAULT_FROM_EMAIL=no-reply@acted.co.uk
DEFAULT_REPLY_TO_EMAIL=acted@bpp.com
PASSWORD_RESET_TIMEOUT_MINUTES=15

# Email Monitoring (optional)
EMAIL_BCC_MONITORING=False
EMAIL_BCC_RECIPIENTS=monitoring@example.com
DEV_EMAIL_OVERRIDE=False
DEV_EMAIL_RECIPIENTS=test@example.com

# Email Queue Settings
EMAIL_QUEUE_BATCH_SIZE=50
EMAIL_QUEUE_INTERVAL=30

# reCAPTCHA Settings
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Payment Gateway Settings
USE_DUMMY_PAYMENT_GATEWAY=True
OPAYO_BASE_URL=https://sandbox.opayo.eu.elavon.com/hosted-payment-pages/vendor/v1/payment-pages
OPAYO_VENDOR_NAME=your_vendor_name
OPAYO_INTEGRATION_KEY=your_integration_key
OPAYO_INTEGRATION_PASSWORD=your_integration_password
OPAYO_VPS_PROTOCOL=4.00
OPAYO_TXTYPE=PAYMENT
OPAYO_VENDOR=your_vendor_id